{
  "homepage": "https://nadasobhy367-art.github.io/noura-ai",
  "name": "noura-ai",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "cra-template-tailwindcss": "4.0.1",
    "crypto-js": "^4.2.0",
    "express": "^4.22.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.561.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^14.3.8",
    "react-icons": "^5.5.0",
    "react-router-dom": "6.30.1",
    "react-scripts": "^5.0.1",
    "recharts": "^3.7.0",
    "uuid": "^9.0.0"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "start": "node scripts/start-frontend.js",
    "start:api": "HOST=127.0.0.1 node server/index.js",
    "pm2-start": "pm2 start ecosystem.config.js",
    "pm2-stop": "pm2 stop ecosystem.config.js || true",
    "pm2-restart": "pm2 restart ecosystem.config.js || pm2 start ecosystem.config.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,md}\"",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^18.19.130",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gh-pages": "^6.3.0",
    "jest": "^27.5.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^4.9.5",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,md}": [
      "prettier --write"
    ]
  }
}
